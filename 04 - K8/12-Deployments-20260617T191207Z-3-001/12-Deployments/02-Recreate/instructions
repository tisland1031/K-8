# Open yaml file and fix TODO for the deployment type Recreate

kubectl apply -f recreate-demo.yaml

kubectl get pods -l app=maintenance-app -L version

#Update yaml image to 1.36 and v2 instead of CLI command (imperitive style)
# -or- go an update yaml and then re-apply (up to you)
kubectl set image deployment/maintenance-app-deployment app-container=busybox:1.36

# Follow deployment
# Q - What do you expect to happen before you execute Recreate deployment?
kubectl get pods -l app=maintenance-app -L version --watch2026-06-14 13:47:07
kubectl get pods -l app=maintenance-app -L version

kubectl rollout status deployment/maintenance-app-deployment

kubectl describe deployment maintenance-app-deployment

kubectl rollout history deployment/maintenance-app-deployment

#Rollback to prev version
kubectl rollout undo deployment/maintenance-app-deployment

#Follow along
kubectl get pods -l app=maintenance-app -L version --watch

# Q - What version is associated with deployment rev2 ?
kubectl rollout history deployment/maintenance-app-deployment --revision=2

# Cleanup
kubectl delete deployment maintenance-app-deployment